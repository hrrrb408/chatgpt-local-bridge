{
  "name": "chatgpt-local-bridge",
  "version": "0.1.0",
  "description": "Let ChatGPT (and other MCP clients) securely read/write local files and run commands via the Model Context Protocol.",
  "keywords": [
    "mcp",
    "chatgpt",
    "filesystem",
    "local-bridge",
    "model-context-protocol"
  ],
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "chatgpt-local-bridge": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postbuild": "node -e \"require('node:fs').chmodSync('dist/index.js',0o755)\"",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "files": [
    "dist",
    "config.example.yaml",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.1.0",
    "js-yaml": "^4.1.0",
    "minimatch": "^9.0.9",
    "nanoid": "^5.0.9",
    "shell-quote": "^1.8.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "@types/shell-quote": "^1.7.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
